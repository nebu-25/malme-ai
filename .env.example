# OpenRouter (AI 모델 중개 서비스) — 실제 키로 교체하세요. 절대 커밋 금지.
VITE_OPENROUTER_API_KEY=sk-or-v1-...
# 기본 모델
VITE_OPENROUTER_MODEL=google/gemini-2.5-flash
# 폴백 모델 (기본 모델 실패 시 순서대로 재시도)
VITE_OPENROUTER_FALLBACK_1=google/gemini-2.5-pro
VITE_OPENROUTER_FALLBACK_2=openai/gpt-audio
# 앱 설정
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=말메 AI
